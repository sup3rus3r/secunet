# ══════════════════════════════════════════════════════════════════
#  SecuNet .env.example
#  Copy to .env and fill in your API key — everything else works
#  as-is for local/lab use. Regenerate secrets before production.
# ══════════════════════════════════════════════════════════════════

# ── LLM Provider ───────────────────────────────────────────────────
# Options: anthropic | openai | lmstudio | fireworks
LLM_PROVIDER=anthropic

# ── Anthropic (default) ────────────────────────────────────────────
# !! REQUIRED — replace with your key !!
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
# Fast/cheap model used for context compression
LLM_COMPRESSION_MODEL=claude-haiku-4-5-20251001

# ── OpenAI (set LLM_PROVIDER=openai to use) ───────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── LM Studio (set LLM_PROVIDER=lmstudio to use) ──────────────────
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=

# ── Fireworks AI (set LLM_PROVIDER=fireworks to use) ──────────────
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3p1-70b-instruct

# ── Mission ────────────────────────────────────────────────────────
# Target scope is set from the dashboard after startup.
# Set here only for headless/automated runs.
TARGET_SCOPE=
MISSION_NAME=default-engagement
AGGRESSION_LEVEL=medium

# ── Context / Memory tuning ────────────────────────────────────────
ROLLING_WINDOW_SIZE=15
COMPRESSION_THRESHOLD=20
SEMANTIC_RESULTS=5
SUMMARY_RESULTS=3
MAX_CONTEXT_TOKENS=2600
DETECTION_THRESHOLD=0.6

# ── Infrastructure (Docker service hostnames — do not change) ──────
REDIS_URL=redis://redis:6379
POSTGRES_URL=postgresql://secunet:secunet@postgres:5432/secunet
CHROMA_PATH=/chroma
MONGO_URL=mongodb://mongo:27017
MONGO_DB_NAME=secunet

# ── Auth secrets (pre-generated — safe for local use) ─────────────
# Regenerate for production: python3 -c "import secrets; print(secrets.token_hex(32))"
ENCRYPTION_KEY=3c6fd8e258d2a2eea4f9ccfbd6088ead94adbecb3c63a38bc79a9e88c440448a
JWT_SECRET_KEY=68bfd027769742be01700a37958d2a2c59e69dc667ce55f6f9f59f7b7e2c0019
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Dashboard / NextAuth ───────────────────────────────────────────
NEXT_PUBLIC_WS_URL=ws://localhost:8001/ws
NEXT_PUBLIC_CC_URL=http://localhost:8001
NEXT_PUBLIC_AUTH_API_URL=http://localhost:8000
BACKEND_INTERNAL_URL=http://backend:8000
AUTH_SECRET=9fcBYppjHrDzi-nRfpq7ov27mdanko5tuAXsUngQ62w=
AUTH_URL=http://localhost:3000
NEXT_PUBLIC_ENCRYPTION_KEY=3c6fd8e258d2a2eea4f9ccfbd6088ead94adbecb3c63a38bc79a9e88c440448a

# ── Threat Intelligence (optional) ────────────────────────────────
SHODAN_API_KEY=
CENSYS_API_ID=
CENSYS_API_SECRET=
VIRUSTOTAL_API_KEY=

# ── SIEM Integration (optional) ───────────────────────────────────
SPLUNK_URL=
SPLUNK_TOKEN=
ELASTIC_URL=
ELASTIC_API_KEY=

# ── Agent tuning ──────────────────────────────────────────────────
RECON_INTERVAL=3600
CRITICAL_RISK_REQUIRES_HITL=true
DC_REQUIRES_HITL=true
